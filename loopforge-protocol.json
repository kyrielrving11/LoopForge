{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://loopforge.dev/loopforge-protocol.json",
  "title": "LoopForge Protocol",
  "description": "JSON Schema for the LoopForge loop-compile protocol. Defines the wire format for all 3 modes (loop_compile, feedback, review) and internal types. Language-agnostic — reference implementation in TypeScript.",
  "type": "object",
  "$defs": {
    "Mode": {
      "type": "string",
      "enum": [
        "loop_compile",
        "feedback"
      ],
      "description": "LoopForge-loop_compile — TypeScript protocol definitions.\n\nAll types exchanged between the Main Agent and LoopForge flow through\nthese interfaces. This is the contract layer — no implementation logic.\n\nv1.15: 40 types — 4 enums + 35 interfaces + 1 type alias."
    },
    "AgentStatus": {
      "type": "string",
      "enum": [
        "ok",
        "error",
        "stalled"
      ]
    },
    "ExecutionFeedback": {
      "type": "object",
      "properties": {
        "output": {
          "type": "string"
        },
        "success": {
          "type": "boolean"
        },
        "constraint_violations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "manual_fixes_needed": {
          "type": "string"
        }
      },
      "required": [
        "output",
        "success",
        "constraint_violations",
        "manual_fixes_needed"
      ]
    },
    "ExecutionEvidence": {
      "type": "object",
      "properties": {
        "files_changed": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "test_results": {
          "type": [
            "string",
            "null"
          ]
        },
        "success_criteria_met": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "success_criteria_remaining": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "progress_estimate": {
          "type": "number"
        }
      },
      "required": [
        "files_changed",
        "success_criteria_met",
        "success_criteria_remaining",
        "progress_estimate"
      ],
      "description": "P4: Structured execution evidence reported by the agent after each round.\nGives LoopForge visibility into what actually happened — files changed,\ntest results, success criteria met, and a subjective progress estimate.\nEnables the compiler to cross-validate agent claims and compute real progress."
    },
    "CriterionRevision": {
      "type": "object",
      "properties": {
        "old": {
          "type": "string"
        },
        "new": {
          "type": "string"
        }
      },
      "required": [
        "old",
        "new"
      ],
      "description": "P5: A revision to a success criterion — the old form and the new form.\nThe agent proposes this when it discovers the original criterion was\nwrong, unrealistic, or needs refinement."
    },
    "SelfEvaluation": {
      "type": "object",
      "properties": {
        "success": {
          "type": "boolean"
        },
        "output_summary": {
          "type": "string"
        },
        "constraint_violations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "should_continue": {
          "type": "boolean"
        },
        "discovered_constraints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "objective_refinement": {
          "type": "string"
        },
        "emerged_subtasks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "execution_evidence": {
          "$ref": "#/$defs/ExecutionEvidence"
        },
        "retracted_constraints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "revised_success_criteria": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/CriterionRevision"
          }
        },
        "wrong_assumptions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "compression_checkpoint": {
          "type": "boolean"
        },
        "checkpoint_label": {
          "type": "string"
        },
        "worker_results": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/WorkerResult"
          }
        },
        "next_action": {
          "type": "string"
        }
      },
      "required": [
        "success",
        "output_summary",
        "constraint_violations",
        "should_continue"
      ],
      "description": "Structured self-evaluation embedded in compiled prompts.\nThe agent outputs this after completing each round.\nEvery field is consumed by at least one downstream function.\n\nv1.4 (P0–P2): Three new optional fields enable cognitive evolution.\nv1.5 (P4–P5): Execution evidence, progress tracking, and self-correction."
    },
    "CheckpointSummary": {
      "type": "object",
      "properties": {
        "label": {
          "type": "string"
        },
        "declared_at_round": {
          "type": "number"
        },
        "outcome": {
          "type": "string"
        },
        "carried_constraints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "resolved_constraints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "label",
        "declared_at_round",
        "outcome",
        "carried_constraints",
        "resolved_constraints"
      ],
      "description": "v1.10: Checkpoint summary — a compressed snapshot of loop state at a\nsubtask boundary. Declared by the Agent via self-evaluation, built by\nthe compiler. Rendered as a fixed block that survives rolling-window\neviction, so constraints and outcomes from completed subtasks remain\nvisible in later rounds."
    },
    "WorkerResult": {
      "type": "object",
      "properties": {
        "agentId": {
          "type": "string"
        },
        "subAgentType": {
          "type": "string"
        },
        "subTask": {
          "type": "string"
        },
        "resultSummary": {
          "type": "string"
        },
        "success": {
          "type": "boolean"
        },
        "discoveredConstraints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "agentId",
        "subAgentType",
        "subTask",
        "resultSummary",
        "success"
      ],
      "description": "A single sub-agent / Worker delegation result (v1.9 — multi-agent)."
    },
    "LoopForgeRequest": {
      "type": "object",
      "properties": {
        "task": {
          "type": "string"
        },
        "mode": {
          "$ref": "#/$defs/Mode"
        },
        "feedback": {
          "anyOf": [
            {
              "$ref": "#/$defs/ExecutionFeedback"
            },
            {
              "type": "null"
            }
          ]
        },
        "skill_name": {
          "type": [
            "string",
            "null"
          ]
        },
        "task_id": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "task",
        "mode"
      ],
      "additionalProperties": true
    },
    "LoopObjective": {
      "type": "object",
      "properties": {
        "objective": {
          "type": "string"
        },
        "success_criteria": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "hard_constraints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "created_at_round": {
          "type": "number"
        },
        "loop_id": {
          "type": "string"
        },
        "version": {
          "type": "number"
        },
        "refinement_history": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "objective",
        "success_criteria",
        "hard_constraints",
        "created_at_round",
        "loop_id"
      ]
    },
    "LoopHealth": {
      "type": "object",
      "properties": {
        "goal_alignment": {
          "type": "number"
        },
        "constraint_integrity": {
          "type": "number"
        },
        "drift_detected": {
          "type": "boolean"
        },
        "strategy_stability": {
          "type": "boolean"
        },
        "task_continuity": {
          "type": "number"
        },
        "escalation_recommended": {
          "type": "string"
        }
      },
      "required": [
        "goal_alignment",
        "constraint_integrity",
        "drift_detected",
        "strategy_stability",
        "task_continuity",
        "escalation_recommended"
      ]
    },
    "RollingSummary": {
      "type": "object",
      "properties": {
        "key_outcomes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "recurring_issues": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "rounds_sampled": {
          "type": "number"
        },
        "generated_at_round": {
          "type": "number"
        },
        "failed_patterns": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "key_outcomes",
        "recurring_issues",
        "rounds_sampled",
        "generated_at_round"
      ]
    },
    "TaskAlignment": {
      "type": "object",
      "properties": {
        "is_aligned": {
          "type": "boolean"
        },
        "alignment_score": {
          "type": "number"
        },
        "warning": {
          "type": "string"
        },
        "escalation": {
          "type": "string"
        }
      },
      "required": [
        "is_aligned",
        "alignment_score",
        "warning",
        "escalation"
      ]
    },
    "LoopRoundResult": {
      "type": "object",
      "properties": {
        "round": {
          "type": "number"
        },
        "success": {
          "type": "boolean"
        },
        "output_summary": {
          "type": "string"
        },
        "constraint_violations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "manual_fixes_needed": {
          "type": "string"
        },
        "discovered_constraints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "objective_refinement": {
          "type": "string"
        },
        "emerged_subtasks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "execution_evidence": {
          "$ref": "#/$defs/ExecutionEvidence"
        },
        "retracted_constraints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "revised_success_criteria": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/CriterionRevision"
          }
        },
        "wrong_assumptions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "worker_results": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/WorkerResult"
          }
        },
        "compression_checkpoint": {
          "type": "boolean"
        },
        "checkpoint_label": {
          "type": "string"
        },
        "next_action": {
          "type": "string"
        }
      },
      "required": [
        "round",
        "success",
        "output_summary",
        "constraint_violations",
        "manual_fixes_needed"
      ]
    },
    "LoopCompileRequest": {
      "type": "object",
      "properties": {
        "mode": {
          "$ref": "#/$defs/Mode"
        },
        "loop_id": {
          "type": "string"
        },
        "round": {
          "type": "number"
        },
        "goal_id": {
          "type": "string"
        },
        "task": {
          "type": "string"
        },
        "domain": {
          "type": "string"
        },
        "next_task_proposal": {
          "type": "string"
        },
        "loop_objective": {
          "anyOf": [
            {
              "$ref": "#/$defs/LoopObjective"
            },
            {
              "type": "null"
            }
          ]
        },
        "plan_source": {
          "type": [
            "string",
            "null"
          ]
        },
        "constraints_from_plan": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "new_since_last_round": {
          "type": "string"
        },
        "last_round_result": {
          "anyOf": [
            {
              "$ref": "#/$defs/LoopRoundResult"
            },
            {
              "type": "null"
            }
          ]
        },
        "force_level": {
          "type": "string"
        },
        "health_check_interval": {
          "type": "number"
        },
        "external_context": {
          "type": "string"
        },
        "max_rounds": {
          "type": "number"
        },
        "verification_flags": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/VerificationFlag"
          }
        },
        "attempt": {
          "type": "number"
        },
        "consecutive_rejections": {
          "type": "number"
        },
        "rejection_notice": {
          "type": "string"
        }
      },
      "required": [
        "mode",
        "loop_id",
        "round",
        "goal_id",
        "task",
        "domain",
        "next_task_proposal",
        "constraints_from_plan",
        "new_since_last_round",
        "force_level",
        "health_check_interval",
        "attempt",
        "consecutive_rejections",
        "rejection_notice"
      ]
    },
    "PromptArtifact": {
      "type": "object",
      "properties": {
        "schemaVersion": {
          "type": "number"
        },
        "roundId": {
          "type": "string"
        },
        "attempt": {
          "type": "number"
        },
        "level": {
          "anyOf": [
            {
              "type": "string",
              "enum": [
                "l0"
              ]
            },
            {
              "type": "string",
              "enum": [
                "l1"
              ]
            },
            {
              "type": "string",
              "enum": [
                "l2"
              ]
            }
          ]
        },
        "levelReasons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "renderedPrompt": {
          "type": "string"
        },
        "promptHash": {
          "type": "string"
        },
        "stateHash": {
          "type": "string"
        },
        "basePromptVersion": {
          "type": "string"
        },
        "includedSections": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "budgetChars": {
          "type": "number"
        },
        "charCount": {
          "type": "number"
        },
        "budgetExceeded": {
          "type": "boolean"
        },
        "generatedAt": {
          "type": "number"
        }
      },
      "required": [
        "schemaVersion",
        "roundId",
        "attempt",
        "level",
        "levelReasons",
        "renderedPrompt",
        "promptHash",
        "stateHash",
        "basePromptVersion",
        "includedSections",
        "budgetChars",
        "charCount",
        "budgetExceeded",
        "generatedAt"
      ],
      "description": "Immutable record of the exact prompt delivered for one round attempt."
    },
    "LoopCompileResponse": {
      "type": "object",
      "properties": {
        "status": {
          "$ref": "#/$defs/AgentStatus"
        },
        "prompt": {
          "type": "string"
        },
        "recompile_level": {
          "type": "string"
        },
        "diff_from_previous": {
          "type": "string"
        },
        "lineage": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "constraints_active": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "constraints_retired": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "loop_id": {
          "type": "string"
        },
        "round": {
          "type": "number"
        },
        "goal_id": {
          "type": "string"
        },
        "goal_text_hash": {
          "type": "string"
        },
        "loop_objective": {
          "anyOf": [
            {
              "$ref": "#/$defs/LoopObjective"
            },
            {
              "type": "null"
            }
          ]
        },
        "loop_health": {
          "anyOf": [
            {
              "$ref": "#/$defs/LoopHealth"
            },
            {
              "type": "null"
            }
          ]
        },
        "task_alignment": {
          "anyOf": [
            {
              "$ref": "#/$defs/TaskAlignment"
            },
            {
              "type": "null"
            }
          ]
        },
        "rolling_summary": {
          "anyOf": [
            {
              "$ref": "#/$defs/RollingSummary"
            },
            {
              "type": "null"
            }
          ]
        },
        "checkpoint_summary": {
          "anyOf": [
            {
              "$ref": "#/$defs/CheckpointSummary"
            },
            {
              "type": "null"
            }
          ]
        },
        "suggested_next_task": {
          "type": "string"
        },
        "plan_source": {
          "type": [
            "string",
            "null"
          ]
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "error": {
          "type": "string"
        },
        "state_file_content": {
          "type": "string"
        },
        "prompt_artifact": {
          "$ref": "#/$defs/PromptArtifact"
        }
      },
      "required": [
        "status",
        "prompt",
        "recompile_level",
        "diff_from_previous",
        "lineage",
        "constraints_active",
        "constraints_retired",
        "loop_id",
        "round",
        "goal_id",
        "goal_text_hash",
        "suggested_next_task",
        "warnings",
        "error"
      ]
    },
    "EvidenceSnapshot": {
      "type": "object",
      "properties": {
        "verified": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "pending": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "invalidated": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "discovered": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "verified",
        "pending",
        "invalidated",
        "discovered"
      ],
      "description": "Aggregated evidence snapshot for the state file Evidence section.\nFour categories give the agent a clear picture of what's been confirmed,\nwhat remains, what was wrong, and what's newly discovered — all derived\nfrom accumulated SelfEvaluation data across rounds."
    },
    "LoopForgeResponse": {
      "type": "object",
      "properties": {
        "status": {
          "$ref": "#/$defs/AgentStatus"
        },
        "prompt": {
          "type": [
            "string",
            "null"
          ]
        },
        "error": {
          "type": [
            "string",
            "null"
          ]
        },
        "state_file_content": {
          "type": "string"
        },
        "prompt_artifact": {
          "$ref": "#/$defs/PromptArtifact"
        }
      },
      "required": [
        "status"
      ]
    },
    "SessionState": {
      "type": "object",
      "properties": {
        "task_id": {
          "type": "string"
        },
        "call_count": {
          "type": "number"
        },
        "success_trend": {
          "type": "array",
          "items": {
            "type": "boolean"
          }
        },
        "current_version": {
          "type": "string"
        },
        "circuit_breaker_count": {
          "type": "number"
        },
        "feedback_buffer": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "required": [
        "task_id",
        "call_count",
        "success_trend",
        "current_version",
        "circuit_breaker_count",
        "feedback_buffer"
      ]
    },
    "AgentLoopResult": {
      "type": "object",
      "properties": {
        "status": {
          "$ref": "#/$defs/AgentStatus"
        },
        "response": {
          "anyOf": [
            {
              "$ref": "#/$defs/LoopForgeResponse"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "status"
      ]
    },
    "RuntimeStatus": {
      "type": "string",
      "enum": [
        "idle",
        "running",
        "stopped",
        "stalled",
        "paused"
      ]
    },
    "RoundContext": {
      "type": "object",
      "properties": {
        "round": {
          "type": "number"
        },
        "roundId": {
          "type": "string"
        },
        "signal": {
          "type": "string"
        },
        "reportProgress": {
          "type": "string"
        }
      },
      "required": [
        "round",
        "signal",
        "reportProgress"
      ]
    },
    "StopReason": {
      "type": "string",
      "enum": [
        "completed",
        "failed",
        "blocked",
        "cancelled",
        "max_rounds",
        "circuit_breaker",
        "stalled",
        "executor_failure",
        "enforcement_terminated",
        "paused",
        "task_complete",
        "stopped"
      ]
    },
    "EnforcementResult": {
      "type": "object",
      "properties": {
        "action": {
          "anyOf": [
            {
              "type": "string",
              "enum": [
                "accept"
              ]
            },
            {
              "type": "string",
              "enum": [
                "reject"
              ]
            },
            {
              "type": "string",
              "enum": [
                "terminate"
              ]
            }
          ]
        },
        "reason": {
          "type": "string"
        },
        "fix_instructions": {
          "type": "string"
        },
        "check": {
          "type": "string"
        }
      },
      "required": [
        "action",
        "reason",
        "fix_instructions"
      ],
      "description": "Result of round-boundary enforcement. Decides whether to accept the round,\nreject it (force the agent to redo the SAME round), or terminate the loop.\n\naccept:    round passes; proceed to next round as normal.\nreject:    agent's self-evaluation or output is invalid; the agent receives\n           a rejection prompt and must redo the same round. Round counter\n           does NOT increment.\nterminate: loop has reached an unrecoverable state; stop immediately with\n           stopReason \"enforcement_terminated\"."
    },
    "RoundStartInfo": {
      "type": "object",
      "properties": {
        "round": {
          "type": "number"
        },
        "roundId": {
          "type": "string"
        },
        "level": {
          "type": "string"
        },
        "prompt": {
          "type": "string"
        }
      },
      "required": [
        "round",
        "level",
        "prompt"
      ]
    },
    "RoundCompleteInfo": {
      "type": "object",
      "properties": {
        "round": {
          "type": "number"
