{
  "name": "loopforge",
  "version": "1.0.0",
  "description": "Loop-Time Intelligence Layer for AI coding agents — per-iteration prompt compiler with structured memory, constraint inheritance, and drift correction.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./compiler": {
      "import": "./dist/loop-compiler.js",
      "types": "./dist/loop-compiler.d.ts"
    },
    "./replay": {
      "import": "./dist/replay.js",
      "types": "./dist/replay.d.ts"
    }
  },
  "bin": {
    "loopforge": "./dist/cli.js"
  },
  "files": [
    "dist",
    "loop_policy.json",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && node dist/generate-schema.js",
    "generate-schema": "tsc && node dist/generate-schema.js",
    "test": "tsc && node dist/generate-schema.js && node --test dist/tests/*.test.js",
    "test:watch": "tsc && node --test --watch dist/tests/*.test.js",
    "check": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kyrielrving11/LoopForge"
  },
  "keywords": [
    "prompt-engineering",
    "ai-agent",
    "loop-compiler",
    "claude-code",
    "llm",
    "cognitive-stability",
    "constraint-management"
  ],
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  }
}
